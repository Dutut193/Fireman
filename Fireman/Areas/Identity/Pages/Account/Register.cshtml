@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/7.2.0/mdb.min.css" />

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
    }

    body {
        background-image: url('/Images/fire-bg.jpg');
        background-size: cover; /* resim ekranı güzel kaplasın */
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .center-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center; /* tam ortalama */
        align-items: center; /* dikey ortalama */
        padding: 20px;
    }

    .card {
        background: rgba(255, 255, 255, 0.70); /* bir tık daha opak */
        backdrop-filter: blur(4px); /* hafif blur */
        border: 1px solid rgba(255, 255, 255, 0.45);
        box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }
</style>

<div class="center-wrapper">
    <div class="card shadow-4" style="width: 420px; border-radius: 18px;">
        <div class="card-body p-4">

            <h3 class="text-center mb-4" style="color:#d32f2f; font-weight:600;">
                Create Account
            </h3>

            <form method="post" asp-route-returnUrl="@Model.ReturnUrl">

                <div class="form-outline mb-4">
                    <input asp-for="Input.UserName" class="form-control" />
                    <label class="form-label" asp-for="Input.UserName">Username</label>
                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                </div>

                <div class="form-outline mb-4">
                    <input asp-for="Input.Email" class="form-control" />
                    <label class="form-label" asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-outline mb-4">
                    <input asp-for="Input.Password" class="form-control" type="password" />
                    <label class="form-label" asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-outline mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" />
                    <label class="form-label" asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button class="btn btn-danger btn-lg w-100 mb-3" style="border-radius: 10px;">
                    Register
                </button>

            </form>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/7.2.0/mdb.min.js"></script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
